# Copy this file to .env and adjust values for your environment.
# Do not commit your real .env or the contents of tailscale/state/.

PRIVOXY_PORT=8118
PRIVATE_DNS_SUFFIXES=corp
PUBLIC_DNS_PRIMARY=8.8.8.8
PUBLIC_DNS_SECONDARY=1.1.1.1
TAILNET_DNS_SERVER=100.100.100.100

# Optional: set this for Headscale or another compatible control plane.
TS_LOGIN_SERVER=

# Pin this to a specific Tailscale version for deterministic upgrades.
TS_VERSION=stable
